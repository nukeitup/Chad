{
  "version": 2,
  "installCommand": "npm ci --include=dev && npx prisma generate",
  "buildCommand": "mkdir -p public && echo 'API Server' > public/index.html",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/test", "destination": "/api" }
  ]
}
