{
  "version": 2,
  "installCommand": "npm ci --include=dev && npx prisma generate",
  "buildCommand": "echo 'Skipping build - using serverless functions'",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
